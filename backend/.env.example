# Database
DATABASE_URL="postgresql://user:password@localhost:5432/foodmagic?schema=public"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# OpenAI API
OPENAI_API_KEY="your-openai-api-key-here"

# Server
PORT=3001
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:19006,exp://192.168.*.*"

# Analytics
ENABLE_ANALYTICS=true
